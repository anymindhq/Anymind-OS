NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
# Project URL — found in Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Anon (public) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service-role key — server-side only, bypasses RLS (optional, falls back to anon key)
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# GLM 5.1 API — Z.AI (required)
# -----------------------------------------------------------------------------
# Base URL for the GLM chat-completions endpoint
GLM_API_URL=https://api.z.ai/api/coding/paas/v4

# Your Z.AI / GLM API key
GLM_API_KEY=your_glm_api_key

# -----------------------------------------------------------------------------
# GitHub Integration (optional)
# -----------------------------------------------------------------------------
# Personal access token for GitHub API calls
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Twitter / X Integration (optional)
# -----------------------------------------------------------------------------
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# -----------------------------------------------------------------------------
# Email / SMTP Integration (optional)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=anymind@agent.ai

# -----------------------------------------------------------------------------
# Composio (optional — advanced tool integrations)
# -----------------------------------------------------------------------------
# API key from https://composio.dev
COMPOSIO_API_KEY=

# Base URL override (defaults to https://backend.composio.dev)
COMPOSIO_BASE_URL=

# Project name used for session routing (defaults to "anymind-main")
COMPOSIO_PROJECT_NAME=anymind-main

# Session pool tuning
COMPOSIO_SESSION_TTL_SECONDS=3600
COMPOSIO_MAX_SESSIONS=10

# -----------------------------------------------------------------------------
# HydraDB (optional — vector memory system)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_HYDRA_DB_API_KEY=
NEXT_PUBLIC_HYDRA_DB_TENANT_ID=

# Sub-tenant identifier, typically per-user (defaults to "anymind")
NEXT_PUBLIC_HYDRA_DB_SUB_TENANT_ID=anymind
NEXT_PUBLIC_FIRECRAWL_API_KEY=
